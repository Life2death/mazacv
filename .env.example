# --- Core (required for AI rewrite) ---------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- App ------------------------------------------------------------------
APP_URL=http://localhost:3000

# --- Auth + usage limits (Phase 3 — optional; tool runs free without these) -
# When set, free-plan limits are enforced and users can sign in.

# Server-side (API routes). These are NOT exposed to the browser.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Client-side (browser). Prefix NEXT_PUBLIC_ to expose safely.
# Same values as SUPABASE_URL and SUPABASE_ANON_KEY above.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Billing (Phase 4 — optional) -----------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
